{
  "manifest_version": 3,
  "name": "Libby Full Width Reader",
  "version": "1.0",
  "description": "Removes max-width constraints on Libby magazine viewer",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://libbyapp.com/*", "*://*.libbyapp.com/*"],
      "css": ["override.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
